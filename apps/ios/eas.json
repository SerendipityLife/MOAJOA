{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "22.17.0",
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "node": "22.17.0",
      "env": {
        "NPM_CONFIG_NODE_LINKER": "hoisted",
        "EXPO_PUBLIC_WEB_URL": "https://moajoa-web.vercel.app"
      }
    },
    "production": {
      "node": "22.17.0",
      "env": {
        "EXPO_PUBLIC_WEB_URL": "https://moajoa-web.vercel.app"
      }
    }
  }
}
