# Used by `supabase functions serve` locally.
# Copy to supabase/.env.local and fill in your dev keys.

ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_PLACES_SERVER_KEY=AIza...
YOUTUBE_API_KEY=AIza...

# When running against local Supabase (supabase start), use the printed local
# service role key from `supabase status`.
SUPABASE_URL=http://kong:8000
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Kakao OAuth — config.toml [auth.external.kakao] env() substitution.
# REST API key = client_id. Client Secret은 Kakao console에서 활성화 필요.
KAKAO_REST_API_KEY=...
KAKAO_CLIENT_SECRET=...
