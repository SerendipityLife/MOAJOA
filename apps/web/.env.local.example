# apps/web/.env.local — copy to .env.local and fill in.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public maps key (HTTP referrer restricted)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIza...

# App origin (used for share link generation)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Open /boards (board list + create + URL paste) on this environment.
# Production has this UNSET — web is share-only, board management lives
# on iOS. Set to "1" in local dev or on Vercel Preview deployments so
# Windows-based collaborators (who can't build iOS) can manage boards
# from the browser. See CLAUDE.md §5 + .planning/dogfooding/v2-backlog.md #4.
NEXT_PUBLIC_ENABLE_DEV_TOOLS=1

# Same secret as Supabase Edge Function. Generate with:
#   openssl rand -hex 32
# Then mirror via: supabase secrets set REVALIDATE_SECRET=<value>
# REVALIDATE_SECRET=
