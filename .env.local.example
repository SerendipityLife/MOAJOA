# ============================================================================
# MOAJOA Environment Variables (root reference — copy relevant subsets to
# apps/web/.env.local and apps/ios/.env.local and supabase/.env.local)
# ============================================================================

# ---- Supabase ---------------------------------------------------------------
# Project URL + keys. Get from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # server-only, NEVER expose to client

# Local dev (after `supabase start`)
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=eyJhbGc...                   # printed by `supabase status`

# ---- Google Maps Platform ---------------------------------------------------
# Enable: Maps JavaScript API, Places API (New), Maps SDK for iOS
# Recommend separate restricted keys per platform.
GOOGLE_MAPS_WEB_KEY=AIza...                       # restrict by HTTP referrer
GOOGLE_MAPS_IOS_KEY=AIza...                       # restrict by iOS bundle ID
GOOGLE_PLACES_SERVER_KEY=AIza...                  # server-only, used by Edge Function

# ---- Anthropic Claude (YouTube extraction LLM) ------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---- YouTube Data API (optional, for richer metadata) -----------------------
# If unset, extraction falls back to oEmbed + transcript scraping only.
YOUTUBE_API_KEY=AIza...

# ---- App URLs ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000         # web origin for share links
EXPO_PUBLIC_WEB_URL=http://localhost:3000         # iOS uses this for share-link previews

# ---- Apple Sign In (iOS native + web fallback) ------------------------------
APPLE_TEAM_ID=
APPLE_SERVICE_ID=com.serendipitylife.moajoa.web
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=                                 # contents of .p8 file (multiline)

# ---- Optional: Analytics ----------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
